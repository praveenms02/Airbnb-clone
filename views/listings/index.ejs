<% layout("layouts/boilerplate") %>
<section class="listings-page">
    <h2 class="p-2">All Listings</h2>

    <div class="row g-4 listings-grid mx-0">
        <% for (let list of allList) { %>
            <% const imageUrl = (list.image && list.image.url) ? list.image.url : "https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=800&q=60"; %>
            <div class="col-12 col-sm-6 col-lg-3">
                <a href="/listings/<%= list._id %>" class="listing-card-link">
                    <article class="card listing-card h-100">
                        <img
                            src="<%= imageUrl %>"
                            class="card-img-top listing-card-img"
                            alt="<%= list.title %>"
                            loading="lazy"
                        >
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title listing-card-title"><%= list.title %></h5>
                            <p class="card-text listing-card-price mt-auto">&#8377; <%= list.price.toLocaleString("en-IN") %> / night</p>
                        </div>
                    </article>
                </a>
            </div>
        <% } %>
    </div>
</section>
