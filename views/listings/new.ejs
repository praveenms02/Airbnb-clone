<% layout("layouts/boilerplate") %>
<section class="form-page">
    <div class="form-shell"> 
        <div class="form-header">
            <h2 class="form-title">Add New Listing</h2>
            <p class="form-subtitle">Fill out the details below to publish a new stay.</p>
        </div>
 
        <form method="POST" action="/listings" enctype="multipart/form-data" class="listing-form needs-validation" novalidate>
            <label class="form-label" for="title">Title</label>
            <input id="title" class="form-control custom-input" type="text" name="listing[title]" placeholder="Enter the title" required />
           
            <label class="form-label" for="description">Description</label>
            <textarea id="description" class="form-control custom-input custom-textarea" name="listing[description]" placeholder="Enter the description" required></textarea>
            
            <!-- <label class="form-label" for="image">Image URL</label>
            <input id="image" class="form-control custom-input" type="text" name="listing[image]" placeholder="Enter the image link / URL" /> -->

            <label class="form-label" for="image">Upload Image</label>
            <input id="image" class="form-control custom-input" type="file" name="listing[image]" accept="image/*" />

            <div class="form-grid">
                <div>
                    <label class="form-label" for="price">Price (per night)</label>
                    <input id="price" class="form-control custom-input" type="number" name="listing[price]" placeholder="Enter the price" required />
                </div>
                <div>
                    <label class="form-label" for="location">Location</label>
                    <input id="location" class="form-control custom-input" type="text" name="listing[location]" placeholder="Enter the location" required />
                </div>
            </div>

            <label class="form-label" for="country">Country</label>
            <input id="country" class="form-control custom-input" type="text" name="listing[country]" placeholder="Enter the country" required />
            <button class="btn btn-dark form-btn" type="submit">Add Listing</button>
        </form>
    </div>
</section>
