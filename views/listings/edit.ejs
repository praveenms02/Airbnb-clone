<% layout("layouts/boilerplate") %>
<section class="form-page">
    <div class="form-shell">
        <div class="form-header">
            <h2 class="form-title">Edit Listing</h2>
            <p class="form-subtitle">Update your listing details and save changes.</p>
        </div>

        <form method="POST" action="/listings/<%= list._id %>?_method=PUT" enctype="multipart/form-data" class="listing-form needs-validation" novalidate>
            <label class="form-label" for="title">Title</label>
            <input id="title" class="form-control custom-input" type="text" name="listing[title]" value="<%= list.title %>" required />

            <label class="form-label" for="description">Description</label>
            <textarea id="description" class="form-control custom-input custom-textarea" name="listing[description]" required><%= list.description %></textarea>

            <!-- <label class="form-label" for="image">Image URL</label>
            <input id="image" class="form-control custom-input" type="text" name="listing[image]" value="<%= list.image.url %>" /> -->

            <label class="form-label" for="image">Upload Image</label>
            <input id="image" class="form-control custom-input" type="file" name="listing[image]" accept="image/*" />
            <% if (list.image && list.image.url) { %>
                <p class="mt-2 mb-0 text-muted">Current image will be kept if you do not upload a new one.</p>
            <% } %>

            <div class="form-grid">
                <div>
                    <label class="form-label" for="price">Price (per night)</label>
                    <input id="price" class="form-control custom-input" type="number" name="listing[price]" value="<%= list.price %>" required />
                </div>
                <div>
                    <label class="form-label" for="location">Location</label>
                    <input id="location" class="form-control custom-input" type="text" name="listing[location]" value="<%= list.location %>" required />
                </div>
            </div>

            <label class="form-label" for="country">Country</label>
            <input id="country" class="form-control custom-input" type="text" name="listing[country]" value="<%= list.country %>" required />

            <button class="btn btn-dark form-btn" type="submit">Update Listing</button>
        </form>
    </div>
</section>
